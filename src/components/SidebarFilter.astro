---
import { getCollection } from "astro:content";
import getUniqueTagsWithCount from "@utils/getUniqueTagsWithCount";

export interface Props {
  activeTag?: string;
}

const { activeTag } = Astro.props;
const posts = await getCollection("blog");
const tags = getUniqueTagsWithCount(posts);
---

<aside class="w-full sm:w-56 lg:w-[220px] flex flex-col pt-2 shrink-0 font-sans mb-8 sm:mb-0 sm:mr-8 lg:mr-12">
  <div class="text-[11px] font-mono tracking-wider text-skin-base border-b border-skin-line pb-2 mb-2 sm:mb-4 uppercase w-full">
    / Filters
  </div>

  <div class="flex sm:flex-col overflow-x-auto sm:overflow-visible items-center sm:items-start no-scrollbar w-full pb-3 sm:pb-0 border-b border-skin-line/30 sm:border-b-0">
    <div class="flex items-center gap-1.5 mr-6 sm:mr-0 sm:mb-3 text-[15px] font-medium text-skin-base shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 opacity-80 hidden sm:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-80 -ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
      </svg>
      Topic
    </div>

    <ul class="flex sm:flex-col gap-5 sm:gap-[7px] sm:ml-[21px] sm:mb-8 items-center sm:items-start shrink-0">
      {tags.map(({ tag, tagName, count }) => {
        const isChecked = activeTag === tag;
        return (
          <li class="shrink-0">
            <label class="flex items-center gap-2.5 text-[14px] group transition-colors cursor-pointer text-skin-base/70 hover:text-skin-base relative">
              <input 
                type="checkbox" 
                value={tag} 
                checked={isChecked}
                class="tag-checkbox peer appearance-none w-3 h-3 border border-skin-accent rounded-[2px] bg-transparent checked:bg-skin-accent checked:border-skin-accent focus:outline-none transition-colors cursor-pointer"
              />
              <svg class="absolute w-2.5 h-2.5 left-[1px] top-[4px] pointer-events-none opacity-0 peer-checked:opacity-100 text-skin-fill sm:top-[4px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="tracking-wide select-none">{tagName} <span class="opacity-60 text-[13px] ml-0.5">({count})</span></span>
            </label>
          </li>
        );
      })}
    </ul>
  </div>
</aside>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const checkboxes = document.querySelectorAll('.tag-checkbox');
    const cards = document.querySelectorAll('li.post-card');

    function updateFilters() {
      const selectedTags = Array.from(checkboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);

      const isTagPage = window.location.pathname.startsWith('/tags/');
      if (isTagPage) {
        if (selectedTags.length > 0) {
          window.location.href = `/posts?tags=${selectedTags.join(',')}`;
        } else {
          window.location.href = `/posts`;
        }
        return;
      }

      cards.forEach(card => {
        const cardTags = card.getAttribute('data-tags')?.split(',') || [];
        if (selectedTags.length === 0) {
          card.classList.remove('hidden');
        } else {
          const hasMatch = selectedTags.some(tag => cardTags.includes(tag));
          if (hasMatch) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        }
      });
      
      const url = new URL(window.location);
      if (selectedTags.length > 0) {
        url.searchParams.set('tags', selectedTags.join(','));
      } else {
        url.searchParams.delete('tags');
      }
      window.history.replaceState({}, '', url);
    }

    const params = new URLSearchParams(window.location.search);
    const tagsParam = params.get('tags');
    if (tagsParam && !window.location.pathname.startsWith('/tags/')) {
      const activeTags = tagsParam.split(',');
      checkboxes.forEach(cb => {
        if (activeTags.includes(cb.value)) cb.checked = true;
      });
      updateFilters();
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', updateFilters);
    });
  });
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
