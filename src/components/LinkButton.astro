---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
  newTab?: boolean;
}

const { href, className, ariaLabel, title, disabled = false, newTab = false } = Astro.props;
---

<a
  href={disabled ? "#" : href}
  tabindex={disabled ? "-1" : "0"}
  class={`group inline-flex items-center gap-1.5 text-sm font-medium no-underline transition-opacity hover:opacity-70 ${className}`}
  aria-label={ariaLabel}
  title={title}
  aria-disabled={disabled}
  target={newTab ? "_blank" : "_self"}
>
  <slot />
</a>

<style>
  a {
    color: rgb(var(--color-accent));
  }
  a svg {
    @apply h-4 w-4 transition-transform group-hover:translate-x-0.5;
    fill: currentColor;
  }
</style>
