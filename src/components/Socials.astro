---
import { SOCIALS } from "@config";
import LinkButton from "./LinkButton.astro";
import socialIcons from "@assets/socialIcons";

export interface Props {
  centered?: boolean;
}

const { centered = false } = Astro.props;
---

<div class={`social-icons ${centered ? "centered" : ""}`}>
  {
    SOCIALS.filter(social => social.active).map(social => (
      <LinkButton
        href={social.href}
        className="social-btn"
        title={social.linkTitle}
        newTab
      >
        <Fragment set:html={socialIcons[social.name]} />
      </LinkButton>
    ))
  }
</div>

<style>
  .social-icons {
    @apply flex flex-wrap gap-2;
  }
  .social-icons.centered {
    @apply justify-center;
  }
  .social-btn {
    @apply p-2 rounded-md transition-colors !no-underline;
    background: rgba(var(--color-border), 0.08);
    color: rgba(var(--color-text-base), 0.6) !important;
  }
  .social-btn:hover {
    background: rgba(var(--color-border), 0.15);
    color: rgb(var(--color-text-base)) !important;
    opacity: 1 !important;
  }
  .social-btn :global(svg) {
    @apply h-4 w-4;
    fill: currentColor;
  }
</style>
