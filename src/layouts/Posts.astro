---
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagination from "@components/Pagination.astro";
import Card from "@components/Card";
import SidebarFilter from "@components/SidebarFilter.astro";
import { SITE } from "@config";

export interface Props {
  currentPage: number;
  totalPages: number;
  paginatedPosts: CollectionEntry<"blog">[];
  showBioBlock?: boolean;
}

const { currentPage, totalPages, paginatedPosts, showBioBlock = false } = Astro.props;
---

<Layout title={`Posts | ${SITE.title}`}>
  <Header activeNav="posts" />
  
  {showBioBlock && (
    <div class="mx-auto w-full max-w-5xl px-4 mt-8 mb-2">
      <div class="w-full bg-skin-fill rounded-lg overflow-hidden border border-skin-accent font-mono text-sm leading-relaxed">
        <div class="flex items-center px-4 py-2.5 border-b border-skin-accent bg-skin-fill">
          <div class="flex space-x-2 opacity-80">
            <div class="w-3 h-3 rounded-full bg-skin-accent"></div>
            <div class="w-3 h-3 rounded-full bg-skin-accent"></div>
            <div class="w-3 h-3 rounded-full bg-skin-accent"></div>
          </div>
          <div class="mx-auto text-[11px] font-bold text-skin-accent tracking-widest uppercase">bio ~ bash</div>
        </div>
        <div class="p-5 text-skin-base">
          <span class="text-skin-accent font-semibold">guest@xylophong</span> <span>~ %</span> cat bio.txt
          <br/>
          <div class="text-skin-base mt-2 mb-2">
            MD + MSc in data science, advisor to the French Minister of Health (public health, prevention, digital). <br/>
            Once in a while, I write about things in an attempt to clarify ideas in my head.
          </div>
          <span class="text-skin-accent font-semibold">guest@xylophong</span> <span>~ %</span> <span class="animate-pulse text-skin-accent">_</span>
        </div>
      </div>
    </div>
  )}

  <div class="mx-auto flex w-full max-w-5xl flex-col sm:flex-row justify-between pt-6 sm:gap-8 px-4">
    <SidebarFilter />
    
    <div id="posts-wrapper" class="flex-1 w-full min-w-0">
      <Main pageTitle="Posts" noPadding={true}>
        <ul>
          {
            paginatedPosts.map(({ data, id }) => (
              <Card href={`/posts/${id}`} frontmatter={data} />
            ))
          }
        </ul>
      </Main>

      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        prevUrl={`/posts${currentPage - 1 !== 1 ? "/" + (currentPage - 1) : ""}`}
        nextUrl={`/posts/${currentPage + 1}`}
      />
    </div>
  </div>

  <Footer noMarginTop={totalPages > 1} />
</Layout>
